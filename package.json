{
  "name": "infinite-unixtime",
  "version": "1.1.4",
  "description": "Infinite(Unlimited) Unixtime - ignore LMT(Local mean time)",
  "keywords": [
    "unix-time",
    "unixtime",
    "time",
    "timestamp",
    "bigint",
    "infinite",
    "epoch",
    "bc",
    "time-conversion"
  ],
  "author": "marker",
  "license": "MIT",
  "homepage": "https://github.com/saro-lab/unixtime-npm",
  "bugs": {
    "url": "https://github.com/saro-lab/unixtime-npm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saro-lab/unixtime-npm.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "build:plain": "tsup"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup": "^4.60.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
